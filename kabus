local function CreateBtn(text, pos, color)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Text = text
    btn.Size = UDim2.new(0.9, 0, 0.25, 0)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Code
    btn.BorderSizePixel = 0
    return btn
end

local PlayBtn = CreateBtn("START INSANE ORBIT", UDim2.new(0.05, 0, 0.25, 0), Color3.fromRGB(0, 120, 0))
local CamBtn = CreateBtn("FREEZE CAMERA", UDim2.new(0.05, 0, 0.52, 0), Color3.fromRGB(0, 80, 150))
local StopBtn = CreateBtn("STOP ALL", UDim2.new(0.05, 0, 0.79, 0), Color3.fromRGB(150, 0, 0))

-- [ 3. CORE LOGIC (ORBIT & CAMERA) ] --
local Active = false
local CamActive = false
local Angle = 0
local CurrentTargetIndex = 1
local LastSwitchTime = 0

RunService.RenderStepped:Connect(function()
    if Active and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = Player.Character.HumanoidRootPart
        local AllPlayers = game.Players:GetPlayers()
        
        -- Camera Freeze Logic
        if CamActive then
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = CFrame.new(MyRoot.Position + Vector3.new(0, 5, 10), MyRoot.Position)
        end

        local Targets = {}
        for _, p in pairs(AllPlayers) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                table.insert(Targets, p)
            end
        end
        
        if #Targets > 0 then
            -- گوهۆڕینا یاریزانی هەر چرکەیەکێ
            if tick() - LastSwitchTime > 1 then
                CurrentTargetIndex = (CurrentTargetIndex % #Targets) + 1
                LastSwitchTime = tick()
            end
            
            local Target = Targets[CurrentTargetIndex]
            if Target and Target.Character then
                local TheirRoot = Target.Character.HumanoidRootPart
                Angle = Angle + 1.2 -- Full Speed
                local x = math.cos(Angle) * 12
                local z = math.sin(Angle) * 12
                
                -- Height 1.0
                MyRoot.CFrame = TheirRoot.CFrame * CFrame.new(x, 1, z)
                MyRoot.Velocity = Vector3.new(0,0,0)
            end
        end
    end
end)

PlayBtn.MouseButton1Click:Connect(function() Active = true end)

CamBtn.MouseButton1Click:Connect(function() 
    CamActive = not CamActive
    CamBtn.Text = CamActive and "CAMERA: FROZEN" or "FREEZE CAMERA"
    if not CamActive then Camera.CameraType = Enum.CameraType.Custom end
end)

StopBtn.MouseButton1Click:Connect(function() 
    Active = false 
    CamActive = false
    Camera.CameraType = Enum.CameraType.Custom
    CamBtn.Text = "FREEZE CAMERA"
end)
