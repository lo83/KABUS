-- [[ 3. مەکینەیا وێرانکرنێ دگەل چاککرنا کامێرێ ]] --
_G.MassBurning = false

ActionBtn.MouseButton1Click:Connect(function()
    _G.MassBurning = not _G.MassBurning
    ActionBtn.Text = _G.MassBurning and "STOP" or "START DESTROY"
    ActionBtn.BackgroundColor3 = _G.MassBurning and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    
    if _G.MassBurning then
        Camera.CameraType = Enum.CameraType.Scriptable
    else
        Camera.CameraType = Enum.CameraType.Custom
    end
    
    task.spawn(function()
        while _G.MassBurning do
            for _, target in pairs(game.Players:GetPlayers()) do
                if target ~= LP and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
                    local TRoot = target.Character.HumanoidRootPart
                    if MyRoot then
                        Camera.CFrame = CFrame.new(TRoot.Position + Vector3.new(0, 12, 18), TRoot.Position)
                        
                        for i = 1, 6 do
                            local T = tick() * 130
                            MyRoot.CFrame = TRoot.CFrame * CFrame.new(math.cos(T)*7, 2, math.sin(T)*7)
                            RS.RenderStepped:Wait()
                        end
                    end
                end
            end
        end
    end)
end)

-- NO-COLLISION
RS.Stepped:Connect(function()
    if _G.MassBurning and LP.Character then
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)
